# ============================================================
# Promo Snatcher — variáveis de ambiente
# Copiar para .env e preencher os campos OBRIGATÓRIOS
# ============================================================

# === OBRIGATÓRIAS ===

# Senha do painel admin (login em /admin)
AUTH_PASSWORD=

# Chave secreta para assinar tokens JWT (gerado automaticamente pelo 'make setup')
AUTH_SECRET=

# API Key do Evolution API — usada pelo backend
# Escolha uma senha forte
EVOLUTION_API_KEY=

# === INFRAESTRUTURA ===

# URL pública desta instância (usada nos short links das mensagens WA/TG)
# PC:         https://snatcher.autibequi.com
# Raspberry:  http://192.168.1.x:6060  (ou outro domínio/tunnel)
PUBLIC_URL=https://snatcher.autibequi.com

# Porta local do frontend (padrão: 6060)
FRONTEND_PORT=6060

# Token do Cloudflare Tunnel (OPCIONAL — só necessário para acesso externo)
# Criar em: dash.cloudflare.com > Zero Trust > Networks > Tunnels
# Se definido: usar 'make start-tunnel' em vez de 'make start'
CLOUDFLARE_TOKEN=

# === OPCIONAIS ===

# Usuário do painel admin (padrão: admin)
AUTH_USERNAME=admin

# Duração do token JWT em horas (padrão: 72)
AUTH_TOKEN_HOURS=72

# Nome da instância Evolution (padrão: default)
EVOLUTION_INSTANCE=default

# Senha do PostgreSQL interno do Evolution (padrão: evolution)
EVOLUTION_DB_PASS=evolution

# Intervalo de scan em minutos (padrão: 30)
SCAN_INTERVAL=30

# Fuso horário para janela de envio (padrão: America/Sao_Paulo)
TZ_NAME=America/Sao_Paulo

# === GOOGLE ANALYTICS (opcional — dados de público) ===
# Criar em: analytics.google.com → Admin → Data Streams → Web
GA_MEASUREMENT_ID=

# === AFILIADOS (opcional — links ganham comissão) ===

# Tag Amazon Associates (ex: snatcher03-20)
AMZ_TRACKING_ID=

# Tool ID Mercado Livre Afiliados
ML_AFFILIATE_TOOL_ID=

# === MERCADO LIVRE API (opcional — fallback para scraping HTML) ===
# Cadastrar em: developers.mercadolivre.com.br
ML_CLIENT_ID=
ML_CLIENT_SECRET=
