# Copiar para .env e ajustar

# Intervalo de scan em minutos (padrão: 30)
SCAN_INTERVAL=30

# Fuso horário para janela de envio WA (padrão: America/Sao_Paulo)
TZ_NAME=America/Sao_Paulo

# Evolution API — chave global
EVOLUTION_API_KEY=promohunter123

# Senha do banco PostgreSQL da Evolution API
EVOLUTION_DB_PASS=evolution123

# Nome da instância WhatsApp
EVOLUTION_INSTANCE=promo-hunter

# URL pública da Evolution API (deixar vazio para local)
# Quando usar Cloudflare Tunnel: https://z-evo.snatcher.autibequi.com
EVOLUTION_SERVER_URL=http://localhost:8181

# Cloudflare Tunnel token
# Criar em: dash.cloudflare.com > Zero Trust > Networks > Tunnels
# Configurar Public Hostnames:
#   promo.snatcher.autibequi.com -> http://promo-hunter-frontend:80
#   z-evo.snatcher.autibequi.com -> http://promo-hunter-evolution:8080
CLOUDFLARE_TOKEN=
