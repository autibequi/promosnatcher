DATABASE_URL=sqlite:///./data/app.db

# WhatsApp provider: "evolution" ou "zapi"
WA_PROVIDER=evolution

# Evolution API — na stack Docker use o hostname do serviço (mesma rede que o backend)
WA_BASE_URL=http://promo-snatcher-evolution:8080
WA_API_KEY=sua-chave-aqui
WA_INSTANCE=minha-instancia

# Z-API (alternativa)
# WA_PROVIDER=zapi
# WA_BASE_URL=https://api.z-api.io
# WA_API_KEY=seu-token-aqui
# WA_INSTANCE=seu-instance-id

# Intervalo global de scan em minutos
SCAN_INTERVAL=30
